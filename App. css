body {
  font-family: Arial, sans-serif;
  background-color: #f4f4f4;
  margin: 0;
}

.container {
  width: 85%;
  margin: 20px auto;
  text-align: center;
}

h1 {
  color: #333;
}

.dashboard {
  display: flex;
  justify-content: space-around;
  background: white;
  padding: 15px;
  margin-bottom: 20px;
  border-radius: 8px;
  font-weight: bold;
}

.filter {
  margin-bottom: 20px;
}

select {
  padding: 5px;
}

table {
  width: 100%;
  border-collapse: collapse;
  background: white;
}

th,
td {
  border: 1px solid #ddd;
  padding: 10px;
}

th {
  background-color: #f2f2f2;
}

button {
  padding: 6px 10px;
  margin: 2px;
  cursor: pointer;
}
